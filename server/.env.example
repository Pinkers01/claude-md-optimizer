# CLAUDE.md Optimizer · server env
# Copy to .env and fill values. Keep .env out of git.

# --- Server ---
PORT=3280
NODE_ENV=production
BASE_PATH=/apps/optimizer
BASE_URL=https://stopmetzoeken.store

# --- Mollie ---
# Live key starts with live_, test key with test_
MOLLIE_API_KEY=test_REPLACE_ME
# Webhook URL Mollie will POST to. Must be public over HTTPS.
MOLLIE_WEBHOOK_URL=https://stopmetzoeken.store/apps/optimizer/api/webhook

# --- SMTP (Strato, port 587 STARTTLS — Hetzner blocks 465) ---
STRATO_SMTP_HOST=smtp.strato.com
STRATO_SMTP_PORT=587
STRATO_SMTP_USER=administrator@stopmetzoeken.store
STRATO_SMTP_PASS=REPLACE_ME
SMTP_FROM_NAME=Pinky Creative Studio
SMTP_FROM_EMAIL=administrator@stopmetzoeken.store
SMTP_REPLY_TO=klantenservice@stopmetzoeken.store

# --- Build artifact ---
BUILD_ZIP_PATH=/srv/optimizer/build/claude-md-optimizer-v1.0.0.zip
BUILD_ZIP_NAME=claude-md-optimizer-v1.0.0.zip
PRODUCT_VERSION=1.0.0

# --- HMAC secrets (32 bytes hex, generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ---
LICENSE_HMAC_SECRET=0a8b073b21963c006e62f96ae70698b89e9689a4e4d0c87b4fd0ab4436ccc4f6
STATS_HMAC_SECRET=61a7df5f89bbe33c059e9fba4b06438058ee389d7f1a46290c9452c866113a22
MASTER_ADMIN_SECRET=REPLACE_ME_FROM_VAULT

# --- Master admin auto-registration ---
MASTER_ADMIN_REGISTRY_URL=https://stopmetzoeken.store/api/admin/apps
MASTER_ADMIN_REGISTER_INTERVAL_MS=300000

# --- Pricing ---
PRICE_CENTS=900
CURRENCY=EUR

# --- Optional: disable outbound network calls in dev ---
# OFFLINE=true

# Master admin orders ingest (Pinky must paste the real secret here)
ORDERS_HMAC_SECRET=
MASTER_ADMIN_BASE=https://stopmetzoeken.store/apps
